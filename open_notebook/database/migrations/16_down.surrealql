-- Migration 16 rollback: remove Book Navigator audiobook support.
DELETE episode_profile WHERE name = "book_navigator";
DELETE speaker_profile WHERE name = "book_navigator_mentor";
REMOVE INDEX IF EXISTS idx_episode_audiobook ON TABLE episode;
REMOVE FIELD IF EXISTS chapter_title ON TABLE episode;
REMOVE FIELD IF EXISTS chapter_index ON TABLE episode;
REMOVE FIELD IF EXISTS audiobook ON TABLE episode;
REMOVE TABLE IF EXISTS audiobook;
